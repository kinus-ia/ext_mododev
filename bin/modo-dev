#!/usr/bin/env bash
# modo-dev: sobe o daemon do modo-dev apontado pra um projeto.
#
# Uso:
#   modo-dev                       # usa o cwd atual
#   modo-dev ~/Kinus/projeto       # usa o path passado
#   MODODEV_TERM_APP=iTerm2 modo-dev   # outro terminal (default: Terminal)
#   MODODEV_INJETAR=off modo-dev   # save-only (sem colar no terminal)

set -e

PROJETO="${1:-$PWD}"
if [ ! -d "$PROJETO" ]; then
  echo "modo-dev: projeto não existe: $1" >&2
  exit 1
fi
PROJETO="$(cd "$PROJETO" && pwd)"

DAEMON="$HOME/Documents/Kinus/modo-dev/daemon.ts"
if [ ! -f "$DAEMON" ]; then
  echo "modo-dev: daemon não achado em $DAEMON" >&2
  exit 1
fi

PID=$(pgrep -f "modo-dev/daemon.ts$" 2>/dev/null || true)
if [ -n "$PID" ]; then
  echo "modo-dev: matando daemon antigo (pid $PID)"
  kill $PID 2>/dev/null || true
  sleep 1
fi

cd "$PROJETO"
echo "modo-dev: subindo daemon em $PROJETO"
exec env MODODEV_MODO=chat MODODEV_INJETAR="${MODODEV_INJETAR:-on}" MODODEV_TERM_APP="${MODODEV_TERM_APP:-Terminal}" bun "$DAEMON"
